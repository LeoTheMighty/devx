{
  "name": "@devx/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "devx CLI \u2014 autonomous development system. Phase 0 surface area: scaffolded entrypoint + commander dispatch (cli301); 10 stubs + config command land in cli302/cfg204; --help annotations in cli303; --version + postinstall in cli304/cli305.",
  "bin": {
    "devx": "./dist/cli.js"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "scripts/postinstall.js",
    "scripts/postinstall-lib.mjs",
    "_devx/config-schema.json",
    "_devx/templates",
    "skills",
    "INSTALL.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/build-info.mjs",
    "postinstall": "node scripts/postinstall.js",
    "test": "node test/schema-smoke.mjs && tsx test/config-io.test.ts && tsx test/config-validate.test.ts && npm run build && npm run typecheck && vitest run",
    "test:schema": "node test/schema-smoke.mjs",
    "test:config-io": "tsx test/config-io.test.ts",
    "test:config-validate": "tsx test/config-validate.test.ts",
    "test:vitest": "vitest run",
    "sync:skills": "node scripts/sync-skills.mjs",
    "typecheck": "tsc --noEmit",
    "install:global": "npm run build && npm i -g ."
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "commander": "^12.1.0",
    "diff2html": "3.4.48",
    "marked": "12.0.2",
    "yaml": "^2.6.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
